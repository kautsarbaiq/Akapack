# ===== AKAPACK WhatsApp Bot — environment =====
# Salin file ini ke `.env` lalu isi nilainya. JANGAN commit `.env`.

# --- WhatsApp Cloud API (Meta) ---
# Token verifikasi webhook (kamu yang tentukan, samakan di Meta App > Webhooks).
WA_VERIFY_TOKEN=ganti-token-verifikasi
# App Secret dari Meta App > Settings > Basic (untuk verifikasi X-Hub-Signature-256).
WA_APP_SECRET=
# JANGAN diisi di produksi. Hanya untuk dev: izinkan webhook tanpa App Secret.
# Bila WA_APP_SECRET kosong DAN flag ini tidak aktif, webhook POST ditolak 403.
WA_ALLOW_INSECURE_WEBHOOK=
# System User token PERMANEN.
WA_ACCESS_TOKEN=
# Phone Number ID dari WhatsApp > API Setup.
WA_PHONE_NUMBER_ID=
WA_GRAPH_API_VERSION=v21.0
# Driver kirim pesan: "api" (produksi, HTTP ke Meta) atau "log" (dev, tulis ke file).
WA_SEND_DRIVER=api

# --- Identitas bot ---
BOT_NAME=Mbak Aka
COMPANY_NAME=Akapack

# --- Eskalasi ke admin (opsional di Fase 0, dipakai penuh di Fase 3) ---
# Nomor WA admin per cabang, format internasional tanpa "+" (mis. 62812xxxx).
ADMIN_WA_BANDUNG=
ADMIN_WA_GARUT=

# --- Antrian / queue ---
# Driver: "redis" (disarankan di VPS) atau "file" (tanpa dependency, untuk dev/volume kecil).
QUEUE_DRIVER=file
REDIS_DSN=tcp://127.0.0.1:6379
# Debounce: tunggu sekian detik setelah pesan TERAKHIR sebelum bot membalas.
DEBOUNCE_SECONDS=4
# Berapa lama message_id (yang sudah dibalas) disimpan untuk dedup (detik).
DEDUP_TTL=86400
# Jeda sebelum mencoba ulang bila kirim balasan gagal (detik).
RETRY_BACKOFF_SECONDS=30
# Batas usia pesan sebelum worker menyerah mencoba ulang (detik).
MAX_RETRY_AGE_SECONDS=600

# --- Penyimpanan lokal (file driver, log, outgoing.log) ---
DATA_DIR=var

# --- Claude API (Fase 1+) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Supabase (Fase 2+, KUNCI PUBLIK SAJA) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
TENANT_ID=00000000-0000-0000-0000-000000000001
OUTLET_BANDUNG=00000000-0000-0000-0000-000000000002
OUTLET_GARUT=00000000-0000-0000-0000-000000000003
