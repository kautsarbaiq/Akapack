{
    "name": "akapack/whatsapp-bot",
    "description": "Bot auto-reply WhatsApp AI untuk AKAPACK (async: receiver -> queue -> worker -> Claude -> Supabase tools).",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "anthropic-ai/sdk": "^0.30.0",
